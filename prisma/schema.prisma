generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" 
  url      = env("DATABASE_URL")
}

// ==========================================
// 1. ЕНАМИ (Довідники статусів)
// ==========================================

enum Currency {
  USD
  UAH
}

enum WorkerRole {
  PREP      // підготовщик
  PAINTER   // маляр
  POLISHER  // полірувальник
  OWNER     // власник (окрема роль для % власника)
  OTHER
}

enum OrderStatus {
  QUEUE           // 🟡 Черга / Очікування
  DISASSEMBLY     // 🛠 Розбірка/Рихтування
  PREP            // ⏳ Підготовка
  PAINT           // 🎨 Фарбування
  ASSEMBLY        // 🧩 Збірка/Полірування
  STOP_PARTS      // ⛔ СТОП: Чекаємо запчастини
  STOP_PAINT      // ⛔ СТОП: Підбір фарби
  DONE            // ✅ Готово (вмикається лічильник простою)
  CLOSED          // 🏁 Закрито (гроші отримані)
  POSTPONED       // ⏸ Відкладено (через обставини клієнта)
}

enum PartStatus {
  NEED_TO_BUY     // 🔴 Треба купити
  ORDERED         // 🟡 Замовлено
  IN_STOCK        // 🟢 Є в наявності
}

enum PhotoType {
  ACT_IN          // Фото-Акт при прийомці (документ)
  PROCESS         // Фото в процесі (для відправки в месенджер)
}

// ==========================================
// 2. ГЛОБАЛЬНІ НАЛАШТУВАННЯ ТА КУРСИ
// ==========================================

model ExchangeRate {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  usdToUah  Decimal  @db.Decimal(10, 4)
  source    String   @default("NBU")
  createdAt DateTime @default(now())
}

model Settings {
  id              String   @id @default("singleton")
  defaultCurrency Currency @default(USD)
  displayCurrency Currency @default(USD)
  autoUpdateRate  Boolean  @default(true)
  updatedAt       DateTime @updatedAt
}

// ==========================================
// 3. ГОЛОВНІ МОДЕЛІ (Клієнт та Авто)
// ==========================================

model Client {
  id        String    @id @default(uuid())
  name      String
  phone     String    @unique
  note      String?   // Для нотаток (напр. "Просив знижку минулого разу")
  
  vehicles  Vehicle[] // Один клієнт може мати кілька авто
  orders    Order[]   // Прямий зв'язок із замовленнями
  
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model Vehicle {
  id          String   @id @default(uuid())
  clientId    String
  plateNumber String   @unique // Для пошуку Історії Авто (напр. AT1234AA)
  make        String   // Марка (напр. Volkswagen)
  model       String   // Модель (напр. Passat)
  year        Int?
  
  client      Client   @relation(fields: [clientId], references: [id])
  orders      Order[]  // Всі ремонти цього конкретного авто
  
  createdAt   DateTime @default(now())
}

// ==========================================
// 4. ЯДРО СИСТЕМИ (Картка замовлення)
// ==========================================

model Order {
  id               String      @id @default(uuid())
  clientId         String
  vehicleId        String
  
  status           OrderStatus @default(QUEUE)
  description      String?     // Загальний опис проблеми
  
  // -- Фінансовий блок (Гнучкість) --
  estimatedPrice   Decimal     @db.Decimal(10, 2) // Орієнтовна ціна (на початку)
  advancePayment   Decimal     @default(0) @db.Decimal(10, 2) // Завдаток
  totalPaid        Decimal     @default(0) @db.Decimal(10, 2) // Скільки вже сплачено по факту
  currency         Currency    @default(UAH)
  baseExchangeRate Decimal?    @db.Decimal(10, 4) // Курс USD→UAH на момент створення
  
  // -- Дати та Таймери --
  readyDate        DateTime?   // Фіксується, коли статус стає DONE (для лічильника простою)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  // -- Зв'язки --
  client           Client      @relation(fields: [clientId], references: [id])
  vehicle          Vehicle     @relation(fields: [vehicleId], references: [id])
  
  works            OrderWork[] // Додаткові роботи (Конструктор)
  parts            OrderPart[] // Запчастини / Матеріали
  photos           OrderPhoto[]// Фото-Архів
  workerShares     WorkerShare[] // Розподіл грошей між майстрами
}

// ==========================================
// 5. КОНСТРУКТОР ТА ФІНАНСИ
// ==========================================

// Додаткові роботи (Поле 1, Поле 2...)
model OrderWork {
  id           String   @id @default(uuid())
  orderId      String
  name         String   // Напр. "Пайка бампера", "Базова робота"
  price        Decimal  @db.Decimal(10, 2)
  currency     Currency @default(UAH)
  exchangeRate Decimal? @db.Decimal(10, 4)

  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Модуль "Запчастини" (План/Факт)
model OrderPart {
  id             String     @id @default(uuid())
  orderId        String
  name           String     // "Ліве крило", "Кліпси"
  articleCode    String?    // Артикул для пошуку в каталозі
  status         PartStatus @default(NEED_TO_BUY)

  estimatedPrice Decimal    @default(0) @db.Decimal(10, 2) // План (озвучили клієнту)
  actualPrice    Decimal?   @db.Decimal(10, 2)             // Факт (реальна витрата)
  currency       Currency   @default(UAH)
  exchangeRate   Decimal?   @db.Decimal(10, 4)

  order          Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

// Фото-Архів
model OrderPhoto {
  id          String    @id @default(uuid())
  orderId     String
  url         String    // Посилання на AWS S3 / Cloudinary
  type        PhotoType @default(PROCESS)
  description String?   // "Авто на стадії ґрунтування" (для шаблону)
  
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

// Розподіл фінансів (Зарплати майстрам)
model WorkerShare {
  id           String      @id @default(uuid())
  orderId      String
  workerName   String      // snapshot імені на момент запису
  workerId     String?     // зв'язок з довідником Worker (nullable для сумісності)
  sharePercent Decimal?    @db.Decimal(5, 2)  // % від залишку (null = фіксована сума)
  roleSnapshot WorkerRole? // роль у цьому замовленні
  amount       Decimal     @db.Decimal(10, 2)
  currency     Currency    @default(UAH)
  exchangeRate Decimal?    @db.Decimal(10, 4)

  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  worker       Worker?     @relation(fields: [workerId], references: [id], onDelete: SetNull)
}

// ==========================================
// 7. ДОВІДНИК КОМАНДИ
// ==========================================

model Worker {
  id           String       @id @default(uuid())
  name         String
  roles        WorkerRole[]
  defaultShare Float?       // дефолтний % (0-100)
  isActive     Boolean      @default(true)
  notes        String?
  sortOrder    Int          @default(0)
  shares       WorkerShare[]
  user         User?
  createdAt    DateTime     @default(now())
}

// ==========================================
// 9. АВТЕНТИФІКАЦІЯ
// ==========================================

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  workerId     String?   @unique
  worker       Worker?   @relation(fields: [workerId], references: [id], onDelete: SetNull)
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 8. ШАБЛОНИ РОЗПОДІЛУ
// ==========================================

model ShareTemplate {
  id          String              @id @default(uuid())
  name        String
  description String?
  rules       ShareTemplateRule[]
  isDefault   Boolean             @default(false)
  sortOrder   Int                 @default(0)
}

model ShareTemplateRule {
  id         String        @id @default(uuid())
  templateId String
  role       WorkerRole
  percent    Float
  template   ShareTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ==========================================
// 6. ГЛОБАЛЬНІ МОДУЛІ (Без прив'язки до замовлення)
// ==========================================

// Модуль "Закупки" (Shopping List)
model ShoppingListItem {
  id          String   @id @default(uuid())
  name        String   // Напр. "Розчинник", "Лак"
  isNeeded    Boolean  @default(false) // Кнопка "Треба купити"
  
  updatedAt   DateTime @updatedAt
}

// Фонд розвитку ("На мрію")
model DreamFund {
  id            String   @id @default(uuid())
  goalName      String   // Напр. "Нова камера"
  targetAmount  Decimal  @db.Decimal(10, 2)
  currentAmount Decimal  @default(0) @db.Decimal(10, 2)
  currency      Currency @default(USD)

  createdAt     DateTime @default(now())
}